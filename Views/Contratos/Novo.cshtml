@using ContratosIA.Models.Enums
@model ContratosIA.Models.ViewModels.ContratoWizardViewModel
@{
    ViewData["Title"] = "Novo Contrato";
    Layout = "_Layout";
}

<div class="pt-28 px-margin-desktop max-w-container-max mx-auto pb-16" x-data="wizard()">
    <div class="max-w-3xl mx-auto">

        <!-- Page Title -->
        <div class="text-center mb-stack-lg">
            <div class="w-16 h-16 bg-primary-fixed rounded-full flex items-center justify-center mx-auto mb-stack-md">
                <span class="material-symbols-outlined text-primary text-[32px]">edit_document</span>
            </div>
            <h1 class="font-headline-lg text-headline-lg text-primary">Novo Contrato</h1>
            <p class="font-body-md text-body-md text-secondary mt-2">Preencha os dados e nossa IA gera o documento completo.</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="bg-error-container text-on-error-container p-4 rounded-xl mb-6 flex items-start gap-3">
                <span class="material-symbols-outlined text-on-error-container text-[24px] mt-0.5">error</span>
                <div>
                    <p class="font-label-md text-label-md text-on-error-container mb-1">Erro ao gerar contrato:</p>
                    <ul class="list-disc list-inside font-body-sm text-body-sm">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    </ul>
                </div>
            </div>
        }

        <!-- Progress Bar -->
        <div class="mb-stack-lg bg-surface-container-lowest p-4 rounded-xl border border-outline-variant bento-card">
            <div class="flex justify-between font-label-sm text-label-sm text-on-surface-variant mb-2">
                <span>Passo <span x-text="step" class="text-primary font-semibold"></span> de 4</span>
                <span x-text="stepLabel()" class="text-primary font-semibold"></span>
            </div>
            <div class="w-full bg-surface-container rounded-full h-2">
                <div class="bg-primary h-2 rounded-full transition-all duration-500" :style="`width: ${(step/4)*100}%`"></div>
            </div>
        </div>

        <form asp-action="Novo" method="post" id="wizardForm">
            @Html.AntiForgeryToken()

            <!-- Step 1: Contract Type -->
            <div x-show="step === 1" x-cloak class="bg-surface-container-lowest p-stack-lg rounded-xl shadow-2xl border border-outline-variant">
                <div class="flex items-center gap-stack-sm mb-stack-md">
                    <span class="material-symbols-outlined text-primary text-[24px]">category</span>
                    <h2 class="font-headline-md text-headline-md text-on-background">Qual tipo de contrato?</h2>
                </div>
                <div class="grid md:grid-cols-2 gap-4">
                    @foreach (var tipo in Enum.GetValues<TipoContrato>())
                    {
                        <label class="cursor-pointer group">
                            <input type="radio" asp-for="Tipo" value="@tipo"
                                   x-model="formData.Tipo" class="sr-only peer" />
                            <div class="border-2 border-outline-variant rounded-xl p-4 peer-checked:border-primary peer-checked:bg-primary-fixed hover:border-primary/50 transition-all group-hover:translate-y-[-2px]">
                                <p class="font-body-md text-body-md font-medium text-on-background">@tipo.ToLabel()</p>
                            </div>
                        </label>
                    }
                </div>
                <div class="flex justify-end mt-stack-lg">
                    <button type="button" @@click="nextStep()"
                            class="bg-primary text-on-primary font-body-md text-body-md px-8 py-3 rounded-full hover:shadow-xl transition-all scale-100 active:scale-95 inline-flex items-center gap-2">
                        Próximo
                        <span class="material-symbols-outlined text-on-primary text-[20px]" style="font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;">arrow_forward</span>
                    </button>
                </div>
            </div>

            <!-- Step 2: Provider Data -->
            <div x-show="step === 2" x-cloak class="bg-surface-container-lowest p-stack-lg rounded-xl shadow-2xl border border-outline-variant">
                <div class="flex items-center gap-stack-sm mb-stack-md">
                    <span class="material-symbols-outlined text-primary text-[24px]">person</span>
                    <h2 class="font-headline-md text-headline-md text-on-background">Dados do Prestador</h2>
                </div>
                <div class="space-y-stack-md">
                    <div>
                        <label class="font-label-sm text-label-sm text-on-surface-variant block mb-1">Nome completo / Razão Social</label>
                        <input asp-for="PrestadorNome" x-model="formData.PrestadorNome" placeholder="Ex: João Silva LTDA"
                               class="w-full border border-outline-variant rounded-lg px-4 py-3 bg-surface-container-lowest font-body-md text-body-md text-on-background focus:ring-2 focus:ring-primary focus:border-primary focus:outline-none transition-colors" />
                    </div>
                    <div>
                        <label class="font-label-sm text-label-sm text-on-surface-variant block mb-1">CPF / CNPJ</label>
                        <input asp-for="PrestadorCpfCnpj" x-model="formData.PrestadorCpfCnpj" placeholder="000.000.000-00"
                               class="w-full border border-outline-variant rounded-lg px-4 py-3 bg-surface-container-lowest font-body-md text-body-md text-on-background focus:ring-2 focus:ring-primary focus:border-primary focus:outline-none transition-colors" />
                    </div>
                    <div>
                        <label class="font-label-sm text-label-sm text-on-surface-variant block mb-1">Endereço completo</label>
                        <input asp-for="PrestadorEndereco" x-model="formData.PrestadorEndereco" placeholder="Rua, número, bairro, cidade - UF"
                               class="w-full border border-outline-variant rounded-lg px-4 py-3 bg-surface-container-lowest font-body-md text-body-md text-on-background focus:ring-2 focus:ring-primary focus:border-primary focus:outline-none transition-colors" />
                    </div>
                </div>
                <div class="flex justify-between mt-stack-lg">
                    <button type="button" @@click="prevStep()"
                            class="border-2 border-outline-variant text-on-surface-variant font-body-md text-body-md px-6 py-3 rounded-full hover:bg-surface-container transition-all inline-flex items-center gap-2">
                        <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;">arrow_back</span>
                        Voltar
                    </button>
                    <button type="button" @@click="nextStep()"
                            class="bg-primary text-on-primary font-body-md text-body-md px-8 py-3 rounded-full hover:shadow-xl transition-all scale-100 active:scale-95 inline-flex items-center gap-2">
                        Próximo
                        <span class="material-symbols-outlined text-on-primary text-[20px]" style="font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;">arrow_forward</span>
                    </button>
                </div>
            </div>

            <!-- Step 3: Client Data -->
            <div x-show="step === 3" x-cloak class="bg-surface-container-lowest p-stack-lg rounded-xl shadow-2xl border border-outline-variant">
                <div class="flex items-center gap-stack-sm mb-stack-md">
                    <span class="material-symbols-outlined text-primary text-[24px]">business</span>
                    <h2 class="font-headline-md text-headline-md text-on-background">Dados do Contratante</h2>
                </div>
                <div class="space-y-stack-md">
                    <div>
                        <label class="font-label-sm text-label-sm text-on-surface-variant block mb-1">Nome completo / Razão Social</label>
                        <input asp-for="ContratanteNome" x-model="formData.ContratanteNome" placeholder="Ex: Maria Souza ME"
                               class="w-full border border-outline-variant rounded-lg px-4 py-3 bg-surface-container-lowest font-body-md text-body-md text-on-background focus:ring-2 focus:ring-primary focus:border-primary focus:outline-none transition-colors" />
                    </div>
                    <div>
                        <label class="font-label-sm text-label-sm text-on-surface-variant block mb-1">CPF / CNPJ</label>
                        <input asp-for="ContratanteCpfCnpj" x-model="formData.ContratanteCpfCnpj" placeholder="000.000.000-00"
                               class="w-full border border-outline-variant rounded-lg px-4 py-3 bg-surface-container-lowest font-body-md text-body-md text-on-background focus:ring-2 focus:ring-primary focus:border-primary focus:outline-none transition-colors" />
                    </div>
                    <div>
                        <label class="font-label-sm text-label-sm text-on-surface-variant block mb-1">Endereço completo</label>
                        <input asp-for="ContratanteEndereco" x-model="formData.ContratanteEndereco" placeholder="Rua, número, bairro, cidade - UF"
                               class="w-full border border-outline-variant rounded-lg px-4 py-3 bg-surface-container-lowest font-body-md text-body-md text-on-background focus:ring-2 focus:ring-primary focus:border-primary focus:outline-none transition-colors" />
                    </div>
                </div>
                <div class="flex justify-between mt-stack-lg">
                    <button type="button" @@click="prevStep()"
                            class="border-2 border-outline-variant text-on-surface-variant font-body-md text-body-md px-6 py-3 rounded-full hover:bg-surface-container transition-all inline-flex items-center gap-2">
                        <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;">arrow_back</span>
                        Voltar
                    </button>
                    <button type="button" @@click="nextStep()"
                            class="bg-primary text-on-primary font-body-md text-body-md px-8 py-3 rounded-full hover:shadow-xl transition-all scale-100 active:scale-95 inline-flex items-center gap-2">
                        Próximo
                        <span class="material-symbols-outlined text-on-primary text-[20px]" style="font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;">arrow_forward</span>
                    </button>
                </div>
            </div>

            <!-- Step 4: Contract Details -->
            <div x-show="step === 4" x-cloak class="bg-surface-container-lowest p-stack-lg rounded-xl shadow-2xl border border-outline-variant">
                <div class="flex items-center gap-stack-sm mb-stack-md">
                    <span class="material-symbols-outlined text-primary text-[24px]">article</span>
                    <h2 class="font-headline-md text-headline-md text-on-background">Objeto do contrato</h2>
                </div>
                <div class="space-y-stack-md">
                    <div>
                        <label class="font-label-sm text-label-sm text-on-surface-variant block mb-1">
                            Descrição do serviço
                            <span class="text-on-surface-variant opacity-60">(máx. 1000 caracteres)</span>
                        </label>
                        <textarea asp-for="DescricaoServico" x-model="formData.DescricaoServico"
                                  rows="5" maxlength="1000" placeholder="Descreva detalhadamente o serviço a ser prestado..."
                                  class="w-full border border-outline-variant rounded-lg px-4 py-3 bg-surface-container-lowest font-body-md text-body-md text-on-background focus:ring-2 focus:ring-primary focus:border-primary focus:outline-none transition-colors resize-none"></textarea>
                        <p class="text-right font-label-sm text-label-sm text-on-surface-variant mt-1">
                            <span x-text="formData.DescricaoServico?.length ?? 0"></span>/1000
                        </p>
                    </div>
                    <div class="grid md:grid-cols-2 gap-4">
                        <div>
                            <label class="font-label-sm text-label-sm text-on-surface-variant block mb-1">Valor (R$)</label>
                            <input asp-for="Valor" type="number" step="0.01" x-model="formData.Valor" placeholder="0,00"
                                   class="w-full border border-outline-variant rounded-lg px-4 py-3 bg-surface-container-lowest font-body-md text-body-md text-on-background focus:ring-2 focus:ring-primary focus:border-primary focus:outline-none transition-colors" />
                        </div>
                        <div>
                            <label class="font-label-sm text-label-sm text-on-surface-variant block mb-1">Prazo</label>
                            <input asp-for="Prazo" x-model="formData.Prazo" placeholder="Ex: 30 dias, 3 meses"
                                   class="w-full border border-outline-variant rounded-lg px-4 py-3 bg-surface-container-lowest font-body-md text-body-md text-on-background focus:ring-2 focus:ring-primary focus:border-primary focus:outline-none transition-colors" />
                        </div>
                    </div>
                    <div>
                        <label class="font-label-sm text-label-sm text-on-surface-variant block mb-1">Cláusulas extras (opcional)</label>
                        <textarea asp-for="ClausulasExtras" x-model="formData.ClausulasExtras"
                                  rows="3" placeholder="Adicione cláusulas específicas que deseja incluir..."
                                  class="w-full border border-outline-variant rounded-lg px-4 py-3 bg-surface-container-lowest font-body-md text-body-md text-on-background focus:ring-2 focus:ring-primary focus:border-primary focus:outline-none transition-colors resize-none"></textarea>
                    </div>
                </div>
                <div class="flex justify-between mt-stack-lg">
                    <button type="button" @@click="prevStep()"
                            class="border-2 border-outline-variant text-on-surface-variant font-body-md text-body-md px-6 py-3 rounded-full hover:bg-surface-container transition-all inline-flex items-center gap-2">
                        <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;">arrow_back</span>
                        Voltar
                    </button>
                    <button type="submit"
                            class="bg-primary text-on-primary font-label-md text-label-md px-10 py-3 rounded-full hover:shadow-xl transition-all scale-100 active:scale-95 inline-flex items-center gap-2 shadow-lg">
                        <span class="material-symbols-outlined text-on-primary text-[20px]" style="font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;">auto_awesome</span>
                        Gerar contrato com IA
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function wizard() {
    return {
        step: 1,
        formData: {
            Tipo: '',
            PrestadorNome: '',
            PrestadorCpfCnpj: '',
            PrestadorEndereco: '',
            ContratanteNome: '',
            ContratanteCpfCnpj: '',
            ContratanteEndereco: '',
            DescricaoServico: '',
            Valor: '',
            Prazo: '',
            ClausulasExtras: ''
        },
        stepLabel() {
            return ['Tipo de contrato', 'Dados do Prestador', 'Dados do Contratante', 'Objeto e valor'][this.step - 1];
        },
        nextStep() { if (this.step < 4) this.step++; },
        prevStep() { if (this.step > 1) this.step--; }
    }
}
</script>
}
