@model ContratosIA.Models.Entities.Contrato
@{
    ViewData["Title"] = Model.Titulo;
    Layout = "_Layout";
}

<div class="pt-28 px-margin-desktop max-w-container-max mx-auto pb-16">
    <div class="flex flex-col lg:flex-row gap-stack-lg">

        <!-- Sidebar -->
        <aside class="w-full lg:w-80 shrink-0">
            <div class="bg-surface-container-lowest p-stack-lg rounded-xl shadow-2xl border border-outline-variant mb-4">
                <div class="flex items-center gap-stack-sm mb-stack-md border-b border-outline-variant pb-stack-md">
                    <span class="material-symbols-outlined text-primary text-[24px]">info</span>
                    <h2 class="font-headline-md text-headline-md text-on-background">Detalhes</h2>
                </div>
                <dl class="space-y-3 font-body-sm text-body-sm">
                    <div>
                        <dt class="font-label-sm text-label-sm text-on-surface-variant">Tipo</dt>
                        <dd class="font-medium text-on-background mt-0.5">@Model.Tipo.ToLabel()</dd>
                    </div>
                    <div>
                        <dt class="font-label-sm text-label-sm text-on-surface-variant">Prestador</dt>
                        <dd class="font-medium text-on-background mt-0.5">@Model.PrestadorNome</dd>
                    </div>
                    <div>
                        <dt class="font-label-sm text-label-sm text-on-surface-variant">Contratante</dt>
                        <dd class="font-medium text-on-background mt-0.5">@Model.ContratanteNome</dd>
                    </div>
                    <div>
                        <dt class="font-label-sm text-label-sm text-on-surface-variant">Valor</dt>
                        <dd class="font-medium text-primary mt-0.5">@Model.Valor.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</dd>
                    </div>
                    <div>
                        <dt class="font-label-sm text-label-sm text-on-surface-variant">Prazo</dt>
                        <dd class="font-medium text-on-background mt-0.5">@Model.Prazo</dd>
                    </div>
                    <div>
                        <dt class="font-label-sm text-label-sm text-on-surface-variant">Status</dt>
                        <dd class="mt-1">
                            <span class="inline-flex items-center gap-1 bg-primary-fixed text-primary px-3 py-1 rounded-full font-label-sm text-label-sm">
                                <span class="material-symbols-outlined text-[14px]" style="font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;">check_circle</span>
                                @Model.Status
                            </span>
                        </dd>
                    </div>
                </dl>
            </div>

            <!-- Actions -->
            <div class="space-y-2">
                <a asp-controller="Contratos" asp-action="BaixarPdf" asp-route-id="@Model.Id"
                   class="flex items-center justify-center gap-2 w-full bg-primary text-on-primary font-label-md text-label-md px-4 py-3 rounded-full hover:shadow-xl transition-all scale-100 active:scale-95 no-underline">
                    <span class="material-symbols-outlined text-on-primary text-[20px]" style="font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;">download</span>
                    Baixar PDF
                </a>
                <button onclick="copiarTexto()"
                        class="flex items-center justify-center gap-2 w-full border-2 border-outline-variant text-on-surface-variant font-label-md text-label-md px-4 py-3 rounded-full hover:bg-surface-container transition-all">
                    <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;">content_copy</span>
                    Copiar texto
                </button>
                <form asp-controller="Contratos" asp-action="Regerar" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            class="flex items-center justify-center gap-2 w-full border-2 border-primary text-primary font-label-md text-label-md px-4 py-3 rounded-full hover:bg-primary-fixed transition-all"
                            onclick="return confirm('Regerar contrato com IA? O texto atual será substituído.')">
                        <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;">auto_awesome</span>
                        Regerar com IA
                    </button>
                </form>
            </div>

            <div class="mt-stack-md">
                <a asp-controller="Dashboard" asp-action="Index"
                   class="inline-flex items-center gap-1 font-body-sm text-body-sm text-on-surface-variant hover:text-primary transition-colors no-underline">
                    <span class="material-symbols-outlined text-[18px]" style="font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;">arrow_back</span>
                    Voltar ao dashboard
                </a>
            </div>
        </aside>

        <!-- Contract Content -->
        <main class="flex-1 bg-surface-container-lowest p-stack-lg rounded-xl shadow-2xl border border-outline-variant min-w-0">
            <div class="flex items-center gap-stack-sm mb-stack-md border-b border-outline-variant pb-stack-md">
                <span class="material-symbols-outlined text-primary text-[24px]">description</span>
                <span class="font-label-md text-label-md uppercase tracking-wider text-on-surface-variant">Contrato Gerado</span>
            </div>
            <div id="contratoTexto" class="font-serif text-[15px] leading-7 whitespace-pre-wrap text-on-background">@Model.Conteudo</div>
        </main>
    </div>
</div>

@section Scripts {
<script>
function copiarTexto() {
    const texto = document.getElementById('contratoTexto').innerText;
    navigator.clipboard.writeText(texto).then(() => {
        const btn = event.currentTarget;
        const originalHTML = btn.innerHTML;
        btn.innerHTML = '<span class="material-symbols-outlined text-[20px]" style="font-variation-settings: \'FILL\' 1, \'wght\' 400, \'GRAD\' 0, \'opsz\' 24;">check</span> Copiado!';
        setTimeout(() => { btn.innerHTML = originalHTML; }, 2000);
    });
}
</script>
}
