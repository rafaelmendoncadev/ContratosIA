@model ContratosIA.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Criar conta";
    Layout = "_Layout";
}

<div class="min-h-screen flex items-center justify-center py-24 px-margin-mobile">
    <div class="bg-surface-container-lowest w-full max-w-md p-stack-lg rounded-xl shadow-2xl border border-outline-variant">
        <div class="text-center mb-stack-lg">
            <div class="w-16 h-16 bg-primary-fixed rounded-full flex items-center justify-center mx-auto mb-stack-md">
                <span class="material-symbols-outlined text-primary text-[32px]">person_add</span>
            </div>
            <h1 class="font-headline-md text-headline-md text-on-background">Criar conta no ContratoIA</h1>
        </div>

        <div asp-validation-summary="All" class="bg-error-container text-on-error-container p-3 rounded-lg mb-4 font-body-sm text-body-sm"></div>

        <form asp-action="Register" method="post" class="space-y-stack-md">
            @Html.AntiForgeryToken()
            <div>
                <label class="font-label-sm text-label-sm text-on-surface-variant block mb-1">Nome completo</label>
                <input asp-for="Nome" type="text" placeholder="Seu nome completo"
                       class="w-full border border-outline-variant rounded-lg px-4 py-3 bg-surface-container-lowest font-body-md text-body-md text-on-background focus:ring-2 focus:ring-primary focus:border-primary focus:outline-none transition-colors" />
                <span asp-validation-for="Nome" class="text-error text-xs font-body-sm"></span>
            </div>
            <div>
                <label class="font-label-sm text-label-sm text-on-surface-variant block mb-1">E-mail</label>
                <input asp-for="Email" type="email" placeholder="seu@email.com"
                       class="w-full border border-outline-variant rounded-lg px-4 py-3 bg-surface-container-lowest font-body-md text-body-md text-on-background focus:ring-2 focus:ring-primary focus:border-primary focus:outline-none transition-colors" />
                <span asp-validation-for="Email" class="text-error text-xs font-body-sm"></span>
            </div>
            <div>
                <label class="font-label-sm text-label-sm text-on-surface-variant block mb-1">Senha</label>
                <input asp-for="Senha" type="password" placeholder="Mínimo 6 caracteres"
                       class="w-full border border-outline-variant rounded-lg px-4 py-3 bg-surface-container-lowest font-body-md text-body-md text-on-background focus:ring-2 focus:ring-primary focus:border-primary focus:outline-none transition-colors" />
                <span asp-validation-for="Senha" class="text-error text-xs font-body-sm"></span>
            </div>
            <div>
                <label class="font-label-sm text-label-sm text-on-surface-variant block mb-1">Confirmar senha</label>
                <input asp-for="ConfirmarSenha" type="password" placeholder="Repita a senha"
                       class="w-full border border-outline-variant rounded-lg px-4 py-3 bg-surface-container-lowest font-body-md text-body-md text-on-background focus:ring-2 focus:ring-primary focus:border-primary focus:outline-none transition-colors" />
                <span asp-validation-for="ConfirmarSenha" class="text-error text-xs font-body-sm"></span>
            </div>
            <button type="submit"
                    class="w-full bg-primary text-on-primary font-label-md text-label-md py-3 rounded-full hover:shadow-xl transition-all scale-100 active:scale-95">
                Criar conta
            </button>
        </form>

        <p class="text-center font-body-sm text-body-sm text-on-surface-variant mt-stack-lg">
            Já tem conta?
            <a asp-controller="Account" asp-action="Login" class="text-primary font-semibold hover:underline">Entrar</a>
        </p>
    </div>
</div>
