<header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-margin-desktop py-4 max-w-container-max mx-auto bg-surface/80 backdrop-blur-md">
    <a href="/" class="flex items-center gap-2.5 no-underline group nav-logo">
        <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 shrink-0">
            <path d="M7 3C7 2.45 7.45 2 8 2H18L25 9V28C25 28.55 24.55 29 24 29H8C7.45 29 7 28.55 7 28V3Z" fill="#00288e"/>
            <path d="M18 2V7C18 8.1 18.9 9 20 9H25L18 2Z" fill="#001453" fill-opacity="0.45"/>
            <rect x="11" y="14" width="9" height="1.8" rx="0.9" fill="white" fill-opacity="0.85"/>
            <rect x="11" y="18.5" width="5.5" height="1.8" rx="0.9" fill="white" fill-opacity="0.55"/>
            <g class="logo-sparkle">
                <path d="M24 17.5C24.5 20 26.5 21.5 29 22C26.5 22.5 24.5 24 24 26.5C23.5 24 21.5 22.5 19 22C21.5 21.5 23.5 20 24 17.5Z" fill="#b8c4ff"/>
            </g>
        </svg>
        <span class="font-headline-md text-headline-md font-bold text-primary">Contrato<span class="text-primary-fixed-dim">IA</span></span>
    </a>
    <nav class="hidden md:flex items-center gap-stack-lg">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Dashboard" asp-action="Index"
               class="font-body-md text-body-md text-secondary hover:text-primary transition-colors no-underline">Dashboard</a>
            <form asp-controller="Account" asp-action="Logout" method="post" class="inline">
                <button type="submit"
                        class="font-body-md text-body-md text-secondary hover:text-error transition-colors">Sair</button>
            </form>
        }
        else
        {
            <a asp-controller="Home" asp-action="Index"
               class="font-body-md text-body-md font-bold text-primary border-b-2 border-primary no-underline">Home</a>
            <a class="font-body-md text-body-md text-secondary hover:text-primary transition-colors no-underline" href="#">Como funciona</a>
            <a class="font-body-md text-body-md text-secondary hover:text-primary transition-colors no-underline" href="#">Preços</a>
        }
    </nav>
    <div class="flex items-center gap-stack-md">
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Contratos" asp-action="Novo"
               class="bg-primary text-on-primary font-body-md text-body-md px-6 py-2 rounded-full scale-95 active:scale-90 transition-transform shadow-lg no-underline">
                <span class="material-symbols-outlined text-on-primary align-middle text-[18px] mr-1" style="font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;">add</span>
                Novo contrato
            </a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login"
               class="font-body-md text-body-md text-primary px-4 py-2 opacity-80 hover:opacity-100 transition-opacity no-underline">Login</a>
            <a asp-controller="Account" asp-action="Register"
               class="bg-primary text-on-primary font-body-md text-body-md px-6 py-2 rounded-full scale-95 active:scale-90 transition-transform shadow-lg no-underline">Começar Grátis</a>
        }
    </div>
    <!-- Mobile menu button -->
    <button class="md:hidden material-symbols-outlined text-primary text-[28px]" x-data @*placeholder for mobile menu*@>menu</button>
</header>