@using ContratosIA.Models.Enums
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — ContratoIA</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-tertiary": "#ffffff",
                        "surface-container-lowest": "#ffffff",
                        "surface-container": "#e9edff",
                        "on-tertiary-fixed": "#00174b",
                        "secondary-fixed": "#e1e3e4",
                        "secondary-container": "#e1e3e4",
                        "on-primary-fixed-variant": "#173bab",
                        "primary-fixed-dim": "#b8c4ff",
                        "surface-container-high": "#e1e8fd",
                        "primary-fixed": "#dde1ff",
                        "background": "#f9f9ff",
                        "surface-variant": "#dce2f7",
                        "tertiary-fixed-dim": "#b4c5ff",
                        "on-error-container": "#93000a",
                        "on-secondary-container": "#626566",
                        "on-surface-variant": "#444653",
                        "inverse-on-surface": "#edf0ff",
                        "surface-container-low": "#f1f3ff",
                        "outline-variant": "#c4c5d5",
                        "surface-bright": "#f9f9ff",
                        "on-secondary-fixed-variant": "#454748",
                        "error": "#ba1a1a",
                        "on-primary-fixed": "#001453",
                        "primary-container": "#1e40af",
                        "surface": "#f9f9ff",
                        "on-error": "#ffffff",
                        "on-secondary-fixed": "#191c1d",
                        "on-background": "#141b2b",
                        "tertiary": "#002e81",
                        "on-surface": "#141b2b",
                        "tertiary-container": "#0042b2",
                        "on-primary-container": "#a8b8ff",
                        "on-secondary": "#ffffff",
                        "inverse-surface": "#293040",
                        "error-container": "#ffdad6",
                        "surface-container-highest": "#dce2f7",
                        "on-tertiary-fixed-variant": "#003ea8",
                        "on-tertiary-container": "#a4b9ff",
                        "outline": "#757684",
                        "secondary": "#5c5f60",
                        "on-primary": "#ffffff",
                        "inverse-primary": "#b8c4ff",
                        "primary": "#00288e",
                        "surface-tint": "#3755c3",
                        "tertiary-fixed": "#dbe1ff",
                        "secondary-fixed-dim": "#c5c7c8",
                        "surface-dim": "#d3daef"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "spacing": {
                        "stack-md": "16px",
                        "stack-lg": "32px",
                        "gutter": "24px",
                        "stack-sm": "8px",
                        "container-max": "1280px",
                        "unit": "8px",
                        "margin-mobile": "16px",
                        "margin-desktop": "48px"
                    },
                    "fontFamily": {
                        "headline-lg": ["Manrope", "sans-serif"],
                        "label-sm": ["Inter", "sans-serif"],
                        "headline-xl": ["Manrope", "sans-serif"],
                        "body-sm": ["Inter", "sans-serif"],
                        "body-md": ["Inter", "sans-serif"],
                        "label-md": ["Inter", "sans-serif"],
                        "body-lg": ["Inter", "sans-serif"],
                        "headline-md": ["Manrope", "sans-serif"]
                    },
                    "fontSize": {
                        "headline-lg": ["32px", {"lineHeight": "1.3", "letterSpacing": "-0.01em", "fontWeight": "600"}],
                        "label-sm": ["12px", {"lineHeight": "1", "fontWeight": "500"}],
                        "headline-xl": ["48px", {"lineHeight": "1.2", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                        "body-sm": ["14px", {"lineHeight": "1.5", "fontWeight": "400"}],
                        "body-md": ["16px", {"lineHeight": "1.5", "fontWeight": "400"}],
                        "label-md": ["14px", {"lineHeight": "1", "letterSpacing": "0.05em", "fontWeight": "600"}],
                        "body-lg": ["18px", {"lineHeight": "1.6", "fontWeight": "400"}],
                        "headline-md": ["24px", {"lineHeight": "1.4", "fontWeight": "600"}]
                    }
                }
            }
        }
    </script>
    <style>
        [x-cloak] { display: none !important; }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .hero-gradient {
            background: radial-gradient(circle at top right, #dde1ff 0%, #f9f9ff 50%, #ffffff 100%);
        }
        .bento-card {
            box-shadow: 0px 4px 20px rgba(30, 64, 175, 0.08);
        }
        .font-serif { font-family: 'Times New Roman', Times, serif; }
        body { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }

        /* ── Logo ── */
        .nav-logo svg { transition: transform 0.3s cubic-bezier(.34,1.56,.64,1); }
        .nav-logo:hover svg { transform: scale(1.05); }
        .nav-logo .logo-sparkle {
            transform-origin: 24px 22px;
            transition: transform 0.3s ease, opacity 0.3s ease;
        }
        .nav-logo:hover .logo-sparkle {
            animation: sparkle-glow 1.4s ease-in-out infinite;
        }
        @@keyframes sparkle-glow {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.25); opacity: 0.75; }
        }
    </style>
</head>
<body class="bg-background text-on-background font-body-md selection:bg-primary-fixed selection:text-on-primary-fixed min-h-screen flex flex-col">
    <script>
        if (window.top !== window.self) {
            window.top.location.replace(window.self.location.href);
        }
    </script>
    <partial name="_SiteHeader" />
    <main class="flex-1">
        @RenderBody()
    </main>
    <footer class="w-full py-stack-lg px-margin-desktop flex flex-col md:flex-row justify-between items-center gap-stack-md bg-surface-container-low border-t border-outline-variant">
        <div class="flex flex-col md:flex-row items-center gap-stack-lg">
            <a href="/" class="flex items-center gap-2 no-underline">
                <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 shrink-0">
                    <path d="M7 3C7 2.45 7.45 2 8 2H18L25 9V28C25 28.55 24.55 29 24 29H8C7.45 29 7 28.55 7 28V3Z" fill="#00288e"/>
                    <path d="M18 2V7C18 8.1 18.9 9 20 9H25L18 2Z" fill="#001453" fill-opacity="0.45"/>
                    <rect x="11" y="14" width="9" height="1.8" rx="0.9" fill="white" fill-opacity="0.85"/>
                    <rect x="11" y="18.5" width="5.5" height="1.8" rx="0.9" fill="white" fill-opacity="0.55"/>
                    <path d="M24 17.5C24.5 20 26.5 21.5 29 22C26.5 22.5 24.5 24 24 26.5C23.5 24 21.5 22.5 19 22C21.5 21.5 23.5 20 24 17.5Z" fill="#b8c4ff"/>
                </svg>
                <span class="font-headline-md text-headline-md font-bold text-primary">Contrato<span class="text-primary-fixed-dim">IA</span></span>
            </a>
            <p class="font-body-sm text-body-sm text-on-surface-variant">&copy; @DateTime.Now.Year ContratoIA. Todos os direitos reservados.</p>
        </div>
        <div class="flex gap-stack-md">
            <a class="font-body-sm text-body-sm text-on-surface-variant hover:text-primary transition-colors" href="#">Termos de Uso</a>
            <a class="font-body-sm text-body-sm text-on-surface-variant hover:text-primary transition-colors" href="#">Privacidade</a>
            <a class="font-body-sm text-body-sm text-on-surface-variant hover:text-primary transition-colors" href="#">Contato</a>
        </div>
    </footer>
    @RenderSection("Scripts", required: false)
</body>
</html>